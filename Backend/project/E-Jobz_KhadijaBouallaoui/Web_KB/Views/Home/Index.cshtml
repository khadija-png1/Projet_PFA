<!-- Masthead-->
<header id="container" class="masthead bg-primary text-white text-center">
    <div class="container d-flex align-items-center flex-column">

        
        <!-- Titre principal -->
        <h1 id="colorlight"class="masthead-heading text-uppercase mb-3">E-JOBZ</h1>

        <!-- Icon Divider -->
        <div class="divider-custom divider-light mb-4">
            <div class="divider-custom-line"></div>
            <div class="divider-custom-icon"><i class="fas fa-star"></i></div>
            <div class="divider-custom-line"></div>
        </div>

        <!-- Sous-titre -->
        <p class="masthead-subheading font-weight-light mb-0">
            Plateforme intelligente pour candidats et recruteurs
        </p>

        <!-- Bouton d'appel à l'action (optionnel) -->
        <a href="#portfolio" class="btn btn-outline-light btn-lg mt-4">
            Découvrir nos services
        </a>
    </div>
</header>




<section class="page-section bg-light">
    <div class="container">
        <h2 class="text-center text-uppercase text-secondary mb-4">
            Pourquoi E-JOBZ ?
        </h2>

        <div class="row text-center">
            <div class="col-md-4">
                <i id="colorgreen"class="fas fa-briefcase fa-3x text-primary mb-3"></i>
                <h4>Offres d’emploi</h4>
                <p>Trouvez des offres adaptées à votre profil et à vos compétences.</p>
            </div>

            <div class="col-md-4">
                <i id="colorgreen" class="fas fa-user-tie fa-3x text-primary mb-3"></i>
                <h4>Recruteurs</h4>
                <p>Publiez des offres et trouvez rapidement les meilleurs talents.</p>
            </div>

            <div class="col-md-4">
                <i id="colorgreen" class="fas fa-search fa-3x text-primary mb-3"></i>
                <h4>Recherche intelligente</h4>
                <p>Filtrez par ville, métier, type de contrat.</p>
            </div>
        </div>
    </div>
</section>
