@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_NavbarLayout.cshtml";
}


<div class="card shadow-sm mb-4 offer-card ">
    <div class="card-body d-flex flex-column justify-content-between">

        <!-- Titre -->
        <h5 class="card-title fw-bold text-primary">
            Titre
        </h5>

        <!-- Infos principales -->
        <div class="mb-2 text-muted small">
            <i class="bi bi-building"></i> .Nom <br />
            <i class="bi bi-geo-alt"></i> Lieu <br />
            <i class="bi bi-calendar"></i> Publié 
        </div>

        <!-- Description courte -->
        <p class="card-text text-truncate" style="max-height: 4.5em;">
            .Description
        </p>

        <!-- Footer -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="badge bg-success">
              TypeContrat
            </span>

            <a
               class="btn btn-outline-primary btn-sm">
                Voir détail
            </a>
        </div>
    </div>
</div>
