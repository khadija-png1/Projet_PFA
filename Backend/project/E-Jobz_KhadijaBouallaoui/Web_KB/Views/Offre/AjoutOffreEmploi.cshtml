@model AjoutOffresEmploiViewModel

@{
    ViewData["Title"] = "Ajouter une offre";
    Layout = "~/Views/Shared/_NavbarLayoutRecruteur.cshtml";
}

<form asp-controller="Offre" asp-action="AjoutOffreEmploi" method="post">
    <input type="hidden" name="OffreEmploiId" value="@Model.Id" />

    <div class="container mt-4">
        <div class="row g-4">

            <!-- ================== FORMULAIRE GAUCHE ================== -->
            <div class="col-lg-8">
                <div class="card shadow-sm p-4 rounded-4 border-0">

                    <h4 class="mb-4 fw-bold text-success">Créer une offre d’emploi</h4>

                    <!-- TITRE -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Titre du poste</label>
                        <input asp-for="Titre" class="form-control" id="inputTitre" placeholder="Ex : Développeur Web" />
                        <span asp-validation-for="Titre" class="text-danger"></span>
                    </div>

                    <!-- LIEU -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Lieu</label>
                        <input asp-for="Lieu" class="form-control" id="inputLieu" placeholder="Ex : Casablanca" />
                        <span asp-validation-for="Lieu" class="text-danger"></span>
                    </div>

                    <!-- TYPE CONTRAT -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Type de contrat</label>
                        <select asp-for="TypeContrat" class="form-select" id="inputTypeContrat">
                            <option value="">-- Sélectionner --</option>
                            <option>CDI</option>
                            <option>CDD</option>
                            <option>Stage</option>
                            <option>Freelance</option>
                        </select>
                        <span asp-validation-for="TypeContrat" class="text-danger"></span>
                    </div>

                    <!-- SALAIRE -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Salaire</label>
                        <input asp-for="Salaire" class="form-control" id="inputSalaire" placeholder="Ex : 8000 MAD" />
                        <span asp-validation-for="Salaire" class="text-danger"></span>
                    </div>

                    <!-- DESCRIPTION -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Description de l’offre</label>
                        <textarea asp-for="Description" class="form-control" id="inputDescription" rows="6"
                                  placeholder="Décrivez le poste, les missions, le profil recherché..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <!-- DATE PUBLICATION (cachée) -->
                    <input type="hidden" asp-for="DatePublication" value="@DateTime.Now" />

                </div>
            </div>
         

            <!-- ================== APERÇU DROITE ================== -->
            <div class="col-lg-4">
                <hr />
<h5 class="fw-bold mt-4">📋 Offres de l’entreprise</h5>

@if (Model.OffresEntreprise != null && Model.OffresEntreprise.Any())
{
    <div class="mt-3">
        @foreach (var offre in Model.OffresEntreprise)
        {
            <div class="card mb-3 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-1">@offre.Titre</h6>

                    <small class="text-muted">
                        @offre.TypeContrat • @offre.Lieu
                    </small>

                    <div class="mt-2">
                        <span class="badge bg-success">@offre.Statut</span>
                        <span class="badge bg-secondary">
                            @offre.DatePublication.ToShortDateString()
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted mt-3">Aucune offre publiée.</p>
}

        </div>
    </div>
</form>

         

<style>
.offer-logo {
    position: absolute;
    top: -20px;
    left: -20px;
    width: 80px;
    height: 80px;
    object-fit: contain;
    border-radius: 12px;
    border: 2px solid #ddd;
    background-color: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    z-index: 10;
}
.job-card {
    background: #fff;
    border-radius: 16px;
    padding: 28px;
    position: relative;
}
.job-header { margin-bottom: 12px; }
.job-title { font-size: 1.6rem; font-weight: 700; color: #2d2d2d; }
.job-company { font-size: 1rem; color: #666; }
.company-name { font-weight: 600; color: rgb(32, 124, 106); }
.job-location { margin-left: 6px; }
.job-infos { display: flex; flex-wrap: wrap; gap: 10px; margin: 16px 0; }
.job-badge { background-color: #f0f4f3; color: rgb(32, 124, 106); padding: 6px 14px; border-radius: 20px; font-size: 0.9rem; font-weight: 500; }
.job-description p { font-size: 0.95rem; line-height: 1.6; color: #444; margin-bottom: 12px; }
.job-action { margin-top: 25px; display: flex; justify-content: flex-end; }
.btnGreen { background-color: rgb(32, 124, 106); border-radius: 30px; font-weight: 600; }
</style>


<script>
const bindText = (inputId, previewId) => {
    const input = document.getElementById(inputId);
    const preview = document.getElementById(previewId);
    if (!input || !preview) return;
    input.addEventListener("input", () => {
        preview.textContent = input.value || "—";
    });
};

// Bind fields
bindText("inputTitre", "previewTitre");
bindText("inputLieu", "previewLieu");
bindText("inputSalaire", "previewSalaire");

// Select TypeContrat
document.getElementById("inputTypeContrat")
    ?.addEventListener("change", e => {
        document.getElementById("previewType").textContent = e.target.value || "—";
    });

// Description textarea
document.getElementById("inputDescription")
    ?.addEventListener("input", e => {
        const preview = document.getElementById("previewDescription");
        preview.innerHTML = "";
        e.target.value.split(/\n+/).filter(p => p.trim() !== "").forEach(p => {
            const para = document.createElement("p");
            para.textContent = p;
            preview.appendChild(para);
        });
    });
</script>
